<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="inertial_macros.xacro" />
  <xacro:include filename="materials_macros.xacro" />

  <!-- BASE LINK-->
  <link name="base_link"></link>

  <!-- BASE FOOTPRINT LINK-->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link" />
    <child link="base_footprint" />
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
  </joint>

  <link name="base_footprint" />

  <!-- CHASSI LINK-->
  <joint name="chassis_joint" type="fixed">
    <parent link="base_link" />
    <child link="chassis" />
    <origin xyz="-0.17 0.0 0.0" />
  </joint>


  <link name="chassis">
    <visual>
      <origin xyz="0.17 0.0 0.0375" />
      <geometry>
        <cylinder radius="0.17" length="0.075" />
      </geometry>
      <xacro:material_white />
    </visual>

    <collision>
      <origin xyz="0.17 0.0 0.0375" />
      <geometry>
        <cylinder radius="0.17" length="0.075" />
      </geometry>
    </collision>

    <xacro:inertial_cylinder mass="0.7" radius="0.17" length="0.075">
      <origin xyz="0.17 0.0 0.0375" rpy="0.0 0.0 0.0" />
    </xacro:inertial_cylinder>
  </link>

  <xacro:gazebo_material_white reference="chassis" />

  <!-- LEFT WHEEL LINK-->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="left_wheel" />
    <origin xyz="0.0 0.1175 0.028" rpy="-${pi/2} 0.0 0.0" />
    <axis xyz="0.0 0.0 1" />
  </joint>


  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.036" length="0.016" />
      </geometry>
      <xacro:material_blue />
    </visual>

    <collision>
      <geometry>
        <sphere radius="0.036" />
      </geometry>
    </collision>

    <xacro:inertial_cylinder mass="0.6" radius="0.036" length="0.016">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
    </xacro:inertial_cylinder>
  </link>

  <xacro:gazebo_material_blue reference="left_wheel" />

  <!--RIGHT
  WHEEL LINK -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="right_wheel" />
    <origin xyz="0.0 -0.1175 0.028" rpy="${pi/2} 0.0 0.0" />
    <axis xyz="0.0 0.0 -1" />
  </joint>


  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.036" length="0.016" />
      </geometry>
      <xacro:material_blue />

    </visual>
    <collision>
      <geometry>
        <sphere radius="0.036" />
      </geometry>
    </collision>

    <xacro:inertial_cylinder mass="0.6" radius="0.036" length="0.016">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
    </xacro:inertial_cylinder>
  </link>

  <xacro:gazebo_material_blue reference="right_wheel" />

  <!-- CASTER WHEEL LINK-->
  <joint name="caster_wheel_link" type="fixed">
    <parent link="chassis" />
    <child link="caster_wheel" />
    <origin xyz="0.284 0.0 0.0" />
  </joint>


  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.008" />
      </geometry>
      <xacro:material_black />
    </visual>

    <collision>
      <geometry>
        <sphere radius="0.008" />
      </geometry>
    </collision>

    <xacro:inertial_sphere mass="1.6" radius="0.008">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
    </xacro:inertial_sphere>
  </link>

  <xacro:gazebo_material_black reference="caster_wheel" />

  <gazebo reference="caster_wheel">
    <mu1 value="0.001" />
    <mu2 value="0.001" />
  </gazebo>

</robot>